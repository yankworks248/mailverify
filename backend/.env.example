PORT=3000
HOST=127.0.0.1
PGHOST=127.0.0.1
PGPORT=5433
PGUSER=verifier
PGPASSWORD=
PGDATABASE=verifier
MOCK_REACHER=false
REACHER_URL=http://127.0.0.1:8080/v0/check_email
VERIFIER_FROM_EMAIL=verifier@inboxaxis.net
REACHER_TIMEOUT_MS=30000
WORKER_CONCURRENCY=4
WORKER_POLL_MS=2000
CORS_ORIGIN=http://localhost:3001

# SESSION_SECRET must be set and at least 32 chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=

# ADMIN_USERNAME and ADMIN_PASSWORD must both be set (no defaults).
# Generate a strong password with:
#   node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
ADMIN_USERNAME=
ADMIN_PASSWORD=
