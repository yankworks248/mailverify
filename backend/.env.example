PORT=3000
HOST=127.0.0.1
PGHOST=127.0.0.1
PGPORT=5433
PGUSER=verifier
PGPASSWORD=
PGDATABASE=verifier
MOCK_REACHER=false
REACHER_URL=http://127.0.0.1:8080/v0/check_email
VERIFIER_FROM_EMAIL=verifier@inboxaxis.net
REACHER_TIMEOUT_MS=30000
WORKER_CONCURRENCY=4
WORKER_POLL_MS=2000
# Idle backoff: when the pending queue is empty, workers wait between
# WORKER_IDLE_MIN_MS and WORKER_IDLE_MAX_MS (growing ~1.5x each empty cycle)
# instead of busy-polling. They snap back to fast polling the instant work
# appears (claim returns rows, or a new bulk job is enqueued).
WORKER_IDLE_MIN_MS=2000
WORKER_IDLE_MAX_MS=20000
# Memoization window for the shared "any pending work?" gate (one cheap EXISTS
# shared across all workers per cycle instead of one claim query each).
WORKER_GATE_TTL_MS=1000

# Auto-prune of old completed verifications (daily at 00:30 IST). Keeps the
# table from bloating to millions of rows. Set retention <=0 to disable.
VERIFICATION_RETENTION_DAYS=7
PRUNE_BATCH_SIZE=10000
PRUNE_BATCH_PAUSE_MS=200

CORS_ORIGIN=http://localhost:3001

# SESSION_SECRET must be set and at least 32 chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=

# ADMIN_USERNAME and ADMIN_PASSWORD must both be set (no defaults).
# Generate a strong password with:
#   node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
ADMIN_USERNAME=
ADMIN_PASSWORD=
